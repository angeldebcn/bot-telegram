# =====================================================
# Variables de entorno del bot
# Copia este archivo a .env y rellena tus valores
# (en Railway añade estos pares directamente en Variables)
# =====================================================

# OBLIGATORIO: token del bot (de @BotFather)
BOT_TOKEN=123456789:ABCDefGHIJKLMNopqrSTUvwxyz

# Tu user_id de Telegram. Lo da @userinfobot.
# Si está vacío, el bot funciona en modo libre (sin licencias).
OWNER_USER_ID=7860549875

# Tu username (sin @). Aparece en los mensajes que invitan a pagar.
OWNER_USERNAME=lapanteraoficial

# Precio mensual mostrado a los clientes (en euros)
SUBSCRIPTION_PRICE_EUR=5

# Activar/desactivar todo el sistema de licencias
# true (default): los grupos no pagados están en pausa
# false: cualquier grupo puede usar el bot gratis
LICENSING_ENABLED=true

# Ruta de la BD. En Railway con volumen, usa /data/bot.db
DB_PATH=/data/bot.db

# Nivel de logs
LOG_LEVEL=INFO
